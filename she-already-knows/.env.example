# Copy to .env for local dev (`netlify dev`). In production these go in
# Netlify → Site settings → Environment variables. NEVER commit the real .env.

# Anthropic (Phase 0)
ANTHROPIC_API_KEY=sk-ant-...

# Flodesk (Phase 1)
FLODESK_API_KEY=fd_key_...

# Supabase (Phase 2) — service_role key, server-side only
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE=eyJ...

# Stripe (Phase 2) — use TEST keys for development, live keys at launch
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...           # the $9.99/mo recurring price
STRIPE_WEBHOOK_SECRET=whsec_...     # from the webhook endpoint you create

# Optional: used to build Stripe success/cancel URLs if request origin is missing
SITE_URL=https://your-site.netlify.app
